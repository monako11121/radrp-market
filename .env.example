# Скопируй этот файл в .env и заполни своими значениями.
# cp .env.example .env

# PostgreSQL — например, Neon, Supabase, или локальный Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth — сгенерируй командой: openssl rand -base64 32
NEXTAUTH_SECRET="REPLACE_WITH_RANDOM_32_BYTE_BASE64_STRING"

# URL приложения (для NextAuth)
NEXTAUTH_URL="http://localhost:3000"

# Comma-separated список email-адресов администраторов
ADMIN_EMAILS="admin@example.com"

# OpenAI — страница поддержки /support
OPENAI_API_KEY="sk-..."
